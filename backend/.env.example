# ============================================================
# MedicoAssist.it — Variabili d'Ambiente
# ============================================================
# Copiare questo file in .env e compilare i valori.
# NON committare MAI .env nel version control!
# ============================================================

# --- Ambiente ---
ENVIRONMENT=development

# ============================================================
# [OBBLIGATORIO] Database — Supabase
# ============================================================
SUPABASE_URL=
SUPABASE_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ============================================================
# [OBBLIGATORIO] Sicurezza — JWT
# ============================================================
JWT_SECRET_KEY=
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ============================================================
# [OBBLIGATORIO] Servizi AI
# ============================================================
GEMINI_API_KEY=

# ============================================================
# [OPZIONALE] Telefonia — Vonage (numeri italiani +39)
# ============================================================
# VONAGE_API_KEY=
# VONAGE_API_SECRET=
# VONAGE_APPLICATION_ID=
# VONAGE_PHONE_NUMBER=

# ============================================================
# [OPZIONALE] Pagamenti — Stripe
# ============================================================
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=

# ============================================================
# [OPZIONALE] Email — SMTP
# ============================================================
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USERNAME=
# SMTP_PASSWORD=
# SMTP_FROM_EMAIL=noreply@medicoassist.it

# ============================================================
# [OPZIONALE] Error Tracking — Sentry
# ============================================================
# SENTRY_DSN=

# ============================================================
# Server
# ============================================================
PORT=8001
